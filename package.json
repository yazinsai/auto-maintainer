{
  "name": "auto-maintainer",
  "version": "0.2.0",
  "description": "Scaffold an autonomous AI-powered repo maintainer onto any GitHub repo",
  "type": "module",
  "bin": {
    "auto-maintainer": "bin/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "files": [
    "dist",
    "bin",
    "templates"
  ],
  "keywords": [
    "github",
    "automation",
    "ai",
    "claude",
    "repo-maintenance"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "yaml": "^2.8.3"
  }
}
